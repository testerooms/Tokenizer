# ─── Anthropic ───────────────────────────────────────────────
# Your organization's master Anthropic API key
# Engineers do NOT need their own keys - they use the proxy
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Proxy Server ────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info

# ─── Database ────────────────────────────────────────────────
DB_PATH=./data/guardian.db

# ─── API Security ────────────────────────────────────────────
# Set a strong random key to protect /api/metrics and /api/alerts endpoints
# The dashboard SPA should include this via VITE_ADMIN_API_KEY
ADMIN_API_KEY=generate-a-random-secret-here

# Comma-separated list of allowed CORS origins for the proxy
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Alerts ──────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
ALERT_EMAIL=finops@yourcompany.com

# ─── Dashboard ───────────────────────────────────────────────
VITE_PROXY_API_URL=http://localhost:3001

# ─── Supabase (Dashboard Auth) ───────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
